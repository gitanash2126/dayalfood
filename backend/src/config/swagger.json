{
  "openapi": "3.0.0",
  "info": {
    "title": "Online Grocery Shop API",
    "version": "1.0.0",
    "description": "API Documentation for the Grocery Shop backend"
  },
  "servers": [
    {
      "url": "http://localhost:3000",
      "description": "Local server"
    }
  ],
  "paths": {
    "/api/auth/login": {
      "post": {
        "summary": "Login user",
        "tags": ["Auth"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "email": { "type": "string" },
                  "password": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Successful login" },
          "401": { "description": "Invalid credentials" }
        }
      }
    },
    "/api/products": {
      "get": {
        "summary": "Get all products",
        "tags": ["Products"],
        "parameters": [
          {
            "in": "query",
            "name": "keyword",
            "schema": { "type": "string" },
            "description": "Search keyword"
          },
          {
            "in": "query",
            "name": "page",
            "schema": { "type": "integer" },
            "description": "Page number"
          }
        ],
        "responses": {
          "200": { "description": "List of products" }
        }
      }
    }
  }
}
